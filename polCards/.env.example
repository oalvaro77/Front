# Policards 2 - Environment Variables

# API URL para el frontend (Vite)
# Desarrollo local: http://localhost:3000
# Producción: https://tu-dominio.vercel.app
VITE_API_URL=

# Vercel KV (Redis) - Se configura automáticamente en Vercel Dashboard
# No es necesario configurar estas variables manualmente en Vercel
# Solo para desarrollo local con Vercel CLI
KV_REST_API_URL=
KV_REST_API_TOKEN=
